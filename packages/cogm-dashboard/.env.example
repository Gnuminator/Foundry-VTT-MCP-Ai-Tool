# ---------------------------------------------------------------------------
# Co-GM dashboard configuration. Copy to ".env" and fill in.
# No secrets are committed — .env is gitignored.
# ---------------------------------------------------------------------------

# Anthropic API key. REQUIRED for AI commentary / "ask the co-GM".
# Without it the dashboard still runs (feed + combat tracker), AI is just disabled.
ANTHROPIC_API_KEY=

# Claude model id (defaults to the latest Opus). Also switchable live in the UI.
# Options: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5
ANTHROPIC_MODEL=claude-opus-4-8

# How often to poll the MCP bridge for new events, in milliseconds.
POLL_INTERVAL_MS=4000

# How often to poll combat state, in milliseconds (defaults to POLL_INTERVAL_MS).
# COMBAT_POLL_INTERVAL_MS=4000

# Minimum spacing between auto-generated comments, in milliseconds (frequency cap).
COMMENT_MIN_INTERVAL_MS=20000

# Debounce window that batches a burst of events into a single comment, in ms.
# COMMENT_DEBOUNCE_MS=1500

# MCP backend control channel (the running bridge). Defaults shown.
MCP_CONTROL_HOST=127.0.0.1
MCP_CONTROL_PORT=31414

# HTTP port for the dashboard + its SSE stream.
PORT=3000

# Starting commentary tone: tactical | narrative
COGM_TONE=tactical

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# --- Module diagnostics (live error feed) ----------------------------------
# How often to poll Foundry module errors/warnings, in milliseconds.
# ERROR_POLL_INTERVAL_MS=6000
# Rolling window size for the in-memory module-error buffer.
# COGM_MAX_ERRORS=100
# Whether the co-GM auto-comments (likely cause + fix) on new module errors.
# Also toggleable live in the UI ("Diag AI").
COGM_COMMENT_ON_ERRORS=true
# Minimum spacing between diagnostics comments, in ms (kept long so it does not
# drown out combat commentary).
# ERROR_COMMENT_MIN_INTERVAL_MS=60000

# --- Control-channel tuning (advanced) -------------------------------------
# Per-request reply timeout; a timeout forces a reconnect.
# MCP_REQUEST_TIMEOUT_MS=15000
# TCP connect timeout.
# MCP_CONNECT_TIMEOUT_MS=5000
# Heartbeat ping cadence (detects a hung / half-open backend).
# MCP_HEARTBEAT_INTERVAL_MS=10000
# Window after the last reply before the channel is treated as stale.
# MCP_STALENESS_THRESHOLD_MS=30000
